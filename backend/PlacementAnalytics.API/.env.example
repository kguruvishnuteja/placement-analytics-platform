# ─── Database ────────────────────────────────────────────────────────────────
# Local development (SQL Server LocalDB)
ConnectionStrings__DefaultConnection="Server=(localdb)\\mssqllocaldb;Database=PlacementAnalyticsDb;Trusted_Connection=True;TrustServerCertificate=True"

# Azure SQL (production)
# ConnectionStrings__DefaultConnection="Server=tcp:<server>.database.windows.net,1433;Database=PlacementAnalyticsDb;User Id=<user>;Password=<password>;Encrypt=True;TrustServerCertificate=False;"

# ─── JWT ─────────────────────────────────────────────────────────────────────
Jwt__Key="REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS"
Jwt__Issuer="PlacementAnalytics"
Jwt__Audience="PlacementAnalyticsUsers"

# ─── CORS ────────────────────────────────────────────────────────────────────
Frontend__Url="http://localhost:5173"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
Email__SmtpHost="smtp.gmail.com"
Email__SmtpPort=587
Email__From="noreply@placement.edu"
Email__Username=""
Email__Password=""

# ─── Azure Blob Storage (for file uploads in production) ─────────────────────
AzureStorage__ConnectionString=""
AzureStorage__ContainerName="resumes"
